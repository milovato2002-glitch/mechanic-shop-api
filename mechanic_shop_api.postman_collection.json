              "raw": "{\n  \"vin\": \"2T1BURHE0FC123456\",\n  \"service_date\": \"2026-04-16\",\n  \"service_desc\": \"Transmission fluid flush\",\n  \"customer_email\": \"bob@email.com\"\n}"
