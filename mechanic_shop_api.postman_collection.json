        },
        {
          "name": "Delete Mechanic (ID 2)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/mechanics/2",
              "host": ["{{base_url}}"],
              "path": ["mechanics", "2"]
            }
          }
        }
      ]
    },
    {
