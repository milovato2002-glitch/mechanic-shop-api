{
  "info": {
    "name": "Mechanic Shop API",
    "description": "Full CRUD for Mechanics, Customers, Service Tickets, and Inventory with auth, rate limiting, caching, and pagination",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"email\": \"alice@email.com\",\n  \"phone\": \"555-1001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/customers/",
              "host": ["{{base_url}}"],
              "path": ["customers", ""]
            }
          }
        },
        {
          "name": "Create Customer 2",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Williams\",\n  \"email\": \"bob@email.com\",\n  \"phone\": \"555-1002\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/customers/",
              "host": ["{{base_url}}"],
              "path": ["customers", ""]
            }
          }
        },
        {
          "name": "Get All Customers (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/customers/?page=1&per_page=10",
              "host": ["{{base_url}}"],
              "path": ["customers", ""],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update Customer (ID 1)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Johnson-Smith\",\n  \"email\": \"alice@email.com\",\n  \"phone\": \"555-1001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/customers/1",
              "host": ["{{base_url}}"],
              "path": ["customers", "1"]
            }
          }
        },
        {
          "name": "Delete Customer (ID 2)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/customers/2",
              "host": ["{{base_url}}"],
              "path": ["customers", "2"]
            }
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@email.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/customers/login",
              "host": ["{{base_url}}"],
              "path": ["customers", "login"]
            }
          }
        },
        {
          "name": "Get My Tickets",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/customers/my-tickets",
              "host": ["{{base_url}}"],
              "path": ["customers", "my-tickets"]
            }
          }
        }
      ]
    },
    {
      "name": "Mechanics",
      "item": [
        {
          "name": "Create Mechanic",
          "request": {
